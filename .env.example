# Example environment configuration for ResearchHub-AI
# Copy this file to `.env` (repo root for frontend envs if needed) and `backend/.env` for backend.
# IMPORTANT: Do not commit files containing real secrets.

# Backend application
APP_ENV=development  # values: development, production
SECRET_KEY=replace_with_a_strong_random_secret_key
USE_BCRYPT=1
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
# Set 0 in local development to allow immediate login after register.
# Set 1 in production to require email verification before login.
REQUIRE_EMAIL_VERIFICATION=0

# Database
# Use an absolute path or leave default to let the app compute an absolute path to backend/researchhub.db
# Example (Windows): sqlite:///C:/path/to/ResearchHub-AI/backend/researchhub.db
# Example (POSIX):   sqlite:////home/user/ResearchHub-AI/backend/researchhub.db
DATABASE_URL=sqlite:///./researchhub.db

# Third-party API keys (placeholders only)
GROQ_API_KEY=replace_with_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_LONGFORM_MODEL=llama-3.3-70b-versatile
# Optional: comma-separated allowlist shown in Settings > AI Model Selection.
# GROQ_ALLOWED_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile,deepseek-r1-distill-llama-70b
NASA_ADS_TOKEN=replace_with_nasa_ads_token
OPENALEX_MAILTO=replace_with_contact_email_optional
CROSSREF_MAILTO=replace_with_contact_email_optional
NCBI_API_KEY=replace_with_ncbi_api_key_optional
UNPAYWALL_MAILTO=replace_with_contact_email_optional

# Google OAuth
GOOGLE_CLIENT_ID=replace_with_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
# Optional explicit callback URI (recommended if your backend port is not 8000)
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Developer access (optional)
# Add one or more developer emails (comma-separated) to enable /developer APIs.
DEVELOPER_EMAILS=dev@example.com
# Optional header key for developer endpoints: send `X-Dev-Key: <value>`
DEV_ACCESS_KEY=replace_with_dev_access_key
# Only used in APP_ENV=development; set 1 to allow /developer access for any authenticated user.
ALLOW_DEV_PANEL=0

# Frontend envs (set in frontend/.env when needed)
VITE_API_URL=http://localhost:8000
SPRINGER_OPEN_ACCESS_KEY=replace_with_springer_open_access_key
SPRINGER_META_KEY=replace_with_springer_meta_key
